{
  "name": "@action-llama/action-llama",
  "version": "0.11.2",
  "description": "Automated development agents triggered by cron or webhooks. BYOM — bring your own model.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Action-Llama/action-llama"
  },
  "keywords": [
    "llm",
    "agent",
    "github",
    "webhook",
    "cron",
    "automation",
    "developer-tools",
    "cli"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "al": "./dist/cli/main.js"
  },
  "main": "./dist/cli/main.js",
  "exports": {
    ".": "./dist/cli/main.js"
  },
  "files": [
    "dist",
    "docker",
    "skills",
    "AGENTS.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && chmod +x dist/cli/main.js && npm run build:assets",
    "build:assets": "echo 'No assets to copy'",
    "clean": "rm -rf dist",
    "prebuild": "npm run clean",
    "prepublishOnly": "npm run build && npm test",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish --tag next",
    "promote": "npm dist-tag add @action-llama/action-llama@$(npm view @action-llama/action-llama dist-tags.next) latest",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@aws-sdk/client-apprunner": "^3.1006.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.1003.0",
    "@aws-sdk/client-codebuild": "^3.1004.0",
    "@aws-sdk/client-dynamodb": "^3.1009.0",
    "@aws-sdk/client-ec2": "^3.1003.0",
    "@aws-sdk/client-ecr": "^3.1003.0",
    "@aws-sdk/client-ecs": "^3.1003.0",
    "@aws-sdk/client-iam": "^3.1003.0",
    "@aws-sdk/client-lambda": "^3.1005.0",
    "@aws-sdk/client-s3": "^3.1004.0",
    "@aws-sdk/client-secrets-manager": "^3.1003.0",
    "@aws-sdk/client-sts": "^3.1003.0",
    "@aws-sdk/client-xray": "^3.1003.0",
    "@aws-sdk/lib-dynamodb": "^3.1009.0",
    "@hono/node-server": "^1.19.11",
    "@inquirer/prompts": "^7",
    "@mariozechner/pi-ai": "^0.56.1",
    "@mariozechner/pi-coding-agent": "^0.56.1",
    "@opentelemetry/api": "^1.8.0",
    "@opentelemetry/auto-instrumentations-node": "^0.50.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.55.0",
    "@opentelemetry/id-generator-aws-xray": "^1.2.0",
    "@opentelemetry/instrumentation-http": "^0.54.0",
    "@opentelemetry/propagator-aws-xray": "^1.25.1",
    "@opentelemetry/sdk-node": "^0.55.0",
    "better-sqlite3": "^12.8.0",
    "commander": "^14.0.3",
    "croner": "latest",
    "hono": "^4.12.5",
    "ink": "^6.8.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "^19.2.4",
    "smol-toml": "^1.6.0"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.2.14",
    "@vitest/coverage-v8": "^4.0.18",
    "ink-testing-library": "^4.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
