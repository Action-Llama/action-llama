{
  "name": "@action-llama/action-llama",
  "version": "0.4.2",
  "description": "Automated development agents triggered by cron or webhooks. BYOM — bring your own model.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/action-llama/action-llama.git"
  },
  "keywords": [
    "llm",
    "agent",
    "github",
    "webhook",
    "cron",
    "automation",
    "developer-tools",
    "cli"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "al": "./dist/cli/main.js"
  },
  "main": "./dist/cli/main.js",
  "exports": {
    ".": "./dist/cli/main.js"
  },
  "files": [
    "dist",
    "docker",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && chmod +x dist/cli/main.js && npm run build:assets",
    "build:assets": "echo 'No assets to copy'",
    "clean": "rm -rf dist",
    "prebuild": "npm run clean",
    "prepublishOnly": "npm run build && npm test",
    "preversion": "npm test",
    "postversion": "git push && git push --tags",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@aws-sdk/client-cloudwatch-logs": "^3.1003.0",
    "@aws-sdk/client-codebuild": "^3.1004.0",
    "@aws-sdk/client-ec2": "^3.1003.0",
    "@aws-sdk/client-ecr": "^3.1003.0",
    "@aws-sdk/client-ecs": "^3.1003.0",
    "@aws-sdk/client-iam": "^3.1003.0",
    "@aws-sdk/client-s3": "^3.1004.0",
    "@aws-sdk/client-secrets-manager": "^3.1003.0",
    "@aws-sdk/client-sts": "^3.1003.0",
    "@inquirer/prompts": "^7",
    "@mariozechner/pi-ai": "^0.56.1",
    "@mariozechner/pi-coding-agent": "^0.56.1",
    "commander": "^14.0.3",
    "croner": "latest",
    "ink": "^6.8.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "^19.2.4",
    "smol-toml": "^1.6.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@vitest/coverage-v8": "^4.0.18",
    "ink-testing-library": "^4.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
