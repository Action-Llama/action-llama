{
  "name": "@action-llama/action-llama",
  "version": "0.20.0",
  "description": "Automated development agents triggered by cron or webhooks. BYOM — bring your own model.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Action-Llama/action-llama",
    "directory": "packages/action-llama"
  },
  "keywords": [
    "llm",
    "agent",
    "github",
    "webhook",
    "cron",
    "automation",
    "developer-tools",
    "cli"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "al": "./dist/cli/main.js"
  },
  "main": "./dist/cli/main.js",
  "exports": {
    ".": "./dist/cli/main.js",
    "./internals/credentials": "./dist/shared/credentials.js",
    "./internals/filesystem-backend": "./dist/shared/filesystem-backend.js",
    "./internals/scheduler": "./dist/scheduler/index.js",
    "./internals/config": "./dist/shared/config.js",
    "./internals/webhook-types": "./dist/webhooks/types.js",
    "./internals/execution": "./dist/execution/execution.js",
    "./internals/scheduler-events": "./dist/scheduler/events.js"
  },
  "files": [
    "dist",
    "drizzle",
    "docker",
    "agent-docs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && chmod +x dist/cli/main.js && npm run build:info && npm run build:assets",
    "build:info": "printf '{\"gitSha\":\"%s\"}' \"$(git rev-parse --short=8 HEAD 2>/dev/null || echo dev)\" > dist/build-info.json",
    "build:assets": "node -e \"const fs=require('fs'),s='../frontend/dist',d='dist/frontend';fs.existsSync(s+'/index.html')?(fs.cpSync(s,d,{recursive:true}),console.log('Copied frontend dist → dist/frontend')):console.log('Frontend dist not found, skipping')\"",
    "clean": "rm -rf dist",
    "prebuild": "npm run clean",
    "db:generate": "drizzle-kit generate",
    "test:playwright": "npx playwright test --config playwright.config.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@inquirer/prompts": "^7",
    "@mariozechner/pi-ai": "^0.56.1",
    "@mariozechner/pi-coding-agent": "^0.56.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@opentelemetry/api": "^1.8.0",
    "@opentelemetry/auto-instrumentations-node": "^0.50.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.55.0",
    "@opentelemetry/resources": "^1.30.1",
    "@opentelemetry/sdk-node": "^0.55.0",
    "@opentelemetry/semantic-conventions": "^1.28.0",
    "better-sqlite3": "^12.8.0",
    "commander": "^14.0.3",
    "croner": "^10.0.1",
    "drizzle-orm": "^0.38.4",
    "hono": "^4.12.5",
    "ink": "^6.8.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "^19.2.4",
    "smol-toml": "^1.6.0",
    "ws": "^8.20.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.2.14",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.30.6",
    "ink-testing-library": "^4.0.0"
  }
}
