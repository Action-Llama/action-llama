{
  "name": "@action-llama/action-llama",
  "version": "0.14.0",
  "description": "Automated development agents triggered by cron or webhooks. BYOM — bring your own model.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Action-Llama/action-llama",
    "directory": "packages/action-llama"
  },
  "keywords": [
    "llm",
    "agent",
    "github",
    "webhook",
    "cron",
    "automation",
    "developer-tools",
    "cli"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "al": "./dist/cli/main.js"
  },
  "main": "./dist/cli/main.js",
  "exports": {
    ".": "./dist/cli/main.js"
  },
  "files": [
    "dist",
    "docker",
    "agent-docs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && chmod +x dist/cli/main.js && npm run build:info && npm run build:assets",
    "build:info": "printf '{\"gitSha\":\"%s\"}' \"$(git rev-parse --short=8 HEAD 2>/dev/null || echo dev)\" > dist/build-info.json",
    "build:assets": "echo 'No assets to copy'",
    "clean": "rm -rf dist",
    "prebuild": "npm run clean",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@inquirer/prompts": "^7",
    "@mariozechner/pi-ai": "^0.56.1",
    "@mariozechner/pi-coding-agent": "^0.56.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@opentelemetry/api": "^1.8.0",
    "@opentelemetry/auto-instrumentations-node": "^0.50.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.55.0",
    "@opentelemetry/resources": "^1.30.1",
    "@opentelemetry/sdk-node": "^0.55.0",
    "@opentelemetry/semantic-conventions": "^1.28.0",
    "better-sqlite3": "^12.8.0",
    "commander": "^14.0.3",
    "croner": "^10.0.1",
    "hono": "^4.12.5",
    "ink": "^6.8.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "^19.2.4",
    "smol-toml": "^1.6.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.2.14",
    "ink-testing-library": "^4.0.0"
  }
}
