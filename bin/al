#!/usr/bin/env bash
set -euo pipefail
# Resolve symlinks, then find the project root (one level above bin/)
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  # If readlink returned a relative path, resolve it relative to the symlink's directory
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" && pwd -P)"
AL_ROOT="$(cd "$SCRIPT_DIR/.." && pwd -P)"
# Find tsx: check local node_modules, then walk up (for monorepo hoisting)
find_tsx() {
  local dir="$AL_ROOT"
  while [ "$dir" != "/" ]; do
    if [ -x "$dir/node_modules/.bin/tsx" ]; then
      echo "$dir/node_modules/.bin/tsx"
      return
    fi
    dir="$(dirname "$dir")"
  done
  echo "tsx"  # fallback to PATH
}
exec "$(find_tsx)" "$AL_ROOT/src/cli/main.ts" "$@"
